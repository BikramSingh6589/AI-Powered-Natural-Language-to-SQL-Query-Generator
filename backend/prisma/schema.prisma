generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  name         String
  email        String         @unique
  passwordHash String
  role         Role           @default(USER)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  
  otps         OTP[]
  refreshTokens RefreshToken[]
  datasets     Dataset[]
  queryHistory QueryHistory[]
}

enum Role {
  USER
  ADMIN
}

model OTP {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Dataset {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  filePath    String
  schemaInfo  Json
  tableName   String         @unique // Name of the dynamically created table
  createdAt   DateTime       @default(now())
  
  queryHistory QueryHistory[]
}

model QueryHistory {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  datasetId       String?
  dataset         Dataset? @relation(fields: [datasetId], references: [id], onDelete: SetNull)
  naturalQuery    String
  generatedSQL    String
  explanation     String?
  status          QueryStatus
  executionTimeMs Int?
  createdAt       DateTime @default(now())
}

enum QueryStatus {
  SUCCESS
  ERROR
}
